# ============================================================
# DataDownloader Docker Environment Configuration
# ============================================================

# --- PostgreSQL / TimescaleDB ---
POSTGRES_USER=datadownloader
POSTGRES_PASSWORD=datadownloader123
POSTGRES_DB=financial_data

# TimescaleDB tuning (auto-detected if not set)
# TS_TUNE_MEMORY=2GB
# TS_TUNE_NUM_CPUS=2

# --- pgAdmin ---
PGADMIN_EMAIL=admin@datadownloader.com
PGADMIN_PASSWORD=admin123

# --- Loader ---
# The DATABASE_URL is auto-constructed from above vars in docker-compose.yml
# Only override if you need custom connection string
# DATABASE_URL=postgresql://datadownloader:datadownloader123@postgres:5432/financial_data
